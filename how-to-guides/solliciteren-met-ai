 .step-head .lede {\n    font-family: var(--font-sans);\n    font-size: clamp(17px, 1.5vw, 19px);\n    line-height: 1.55;\n    color: var(--dark-blue);\n    margin: 0;\n    max-width: 60ch;\n  }\n\n  /* Subhead within step */\n  .sub-h {\n    font-family: var(--font-sans);\n    font-weight: 900;\n    font-size: clamp(22px, 2vw, 28px);\n    line-height: 1.2;\n    letter-spacing: -0.01em;\n    color: var(--dark-blue);\n    margin: 48px 0 12px;\n  }\n  .sub-h .tp { color: var(--clear-blue); }\n  .sub-h.first { margin-top: 0; }\n  .sub-h .num {\n    display: inline-block;\n    margin-right: 10px;\n    color: var(--clear-blue);\n    font-family: var(--font-serif);\n    font-weight: 700;\n    font-style: italic;\n  }\n\n  p { color: var(--dark-blue); }\n  .lede {\n    font-family: var(--font-sans);\n    font-size: clamp(17px, 1.5vw, 19px);\n    line-height: 1.55;\n  }\n\n  /* Intro grey card spanning full width but contained */\n  .intro p {\n    font-family: var(--font-sans);\n    font-size: clamp(18px, 1.6vw, 21px);\n    line-height: 1.55;\n    color: var(--dark-blue);\n    max-width: 60ch;\n    text-wrap: pretty;\n  }\n  .intro .pull {\n    font-family: var(--font-serif);\n    font-style: italic;\n    font-weight: 400;\n    font-size: clamp(22px, 2.2vw, 28px);\n    line-height: 1.3;\n    color: var(--dark-blue);\n    border-left: 2px solid var(--orange);\n    padding-left: 20px;\n    margin: 0 0 0;\n    max-width: 30ch;\n  }\n\n  /* Section divider — fine rule */\n  .rule {\n    border: 0;\n    border-top: 1px solid var(--border);\n    margin: 0;\n    max-width: 1120px;\n    margin: 0 auto;\n  }\n\n  /* ——— Callout blocks ——— */\n  .callout {\n    border-radius: var(--r-md);\n    padding: 20px 24px;\n    margin: 20px 0;\n  }\n  .callout .clbl {\n    font-family: var(--font-sans);\n    font-weight: 700;\n    font-size: 11px;\n    letter-spacing: 0.22em;\n    text-transform: uppercase;\n    margin: 0 0 8px;\n    display: inline-flex;\n    align-items: center;\n    gap: 8px;\n  }\n  .callout .clbl::before {\n    content: \"\";\n    display: inline-block;\n    width: 6px;\n    height: 6px;\n    border-radius: 999px;\n    background: currentColor;\n  }\n  .callout p { margin: 0; font-size: 15px; line-height: 1.55; }\n\n  .tip {\n    background: rgba(118,140,214,0.14);\n    border-left: 3px solid var(--clear-blue);\n  }\n  .tip .clbl { color: var(--clear-blue); }\n  .tip p { color: var(--dark-blue); }\n\n  .watch {\n    background: rgba(216,100,18,0.08);\n    border-left: 3px solid var(--orange);\n  }\n  .watch .clbl { color: var(--orange); }\n  .watch p { color: var(--dark-blue); }\n\n  .result {\n    background: rgba(3,40,95,0.05);\n    border-left: 3px solid var(--grey-blue);\n  }\n  .result .clbl { color: var(--grey-blue); }\n  .result p { color: var(--dark-blue); }\n\n  /* ——— Prompt block (dark blue) ——— */\n  .prompt {\n    background: var(--dark-blue);\n    color: var(--fg-on-dark);\n    border-radius: var(--r-md);\n    padding: 24px 28px 22px;\n    margin: 20px 0;\n    position: relative;\n    box-shadow: var(--shadow-card);\n  }\n  .prompt__head {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 12px;\n    margin: 0 0 14px;\n  }\n  .prompt__lbl {\n    font-family: var(--font-sans);\n    font-weight: 700;\n    font-size: 11px;\n    letter-spacing: 0.22em;\n    text-transform: uppercase;\n    color: var(--orange);\n    display: inline-flex;\n    align-items: center;\n    gap: 10px;\n  }\n  .prompt__lbl::before {\n    content: \"\";\n    display: inline-block;\n    width: 18px;\n    height: 1px;\n    background: var(--orange);\n  }\n  .prompt__copy {\n    appearance: none;\n    background: transparent;\n    color: var(--fg-on-dark-2);\n    border: 1px solid rgba(247,246,242,0.2);\n    border-radius: 999px;\n    padding: 6px 12px;\n    font-family: var(--font-sans);\n    font-weight: 500;\n    font-size: 11px;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    cursor: pointer;\n    transition: background var(--dur) var(--ease), color var(--dur) var(--ease), border-color var(--dur) var(--ease);\n    display: inline-flex;\n    align-items: center;\n    gap: 6px;\n  }\n  .prompt__copy:hover {\n    background: rgba(247,246,242,0.08);\n    color: #fff;\n    border-color: rgba(247,246,242,0.4);\n  }\n  .prompt__copy.is-copied {\n    background: var(--orange);\n    border-color: var(--orange);\n    color: #fff;\n  }\n  .prompt__copy svg { width: 12px; height: 12px; }\n  .prompt__body {\n    font-family: var(--font-serif);\n    font-style: italic;\n    font-size: clamp(17px, 1.6vw, 20px);\n    line-height: 1.5;\n    color: var(--fg-on-dark);\n    margin: 0;\n    text-wrap: pretty;\n  }\n  .prompt__body p { margin: 0 0 10px; color: inherit; font-family: inherit; font-size: inherit; line-height: inherit; }\n  .prompt__body p:last-child { margin-bottom: 0; }\n\n  /* ——— Pre-start project card ——— */\n  .start-card {\n    background: var(--dark-blue);\n    color: var(--fg-on-dark);\n    border-radius: var(--r-lg);\n    padding: clamp(32px, 4vw, 48px);\n    margin: 8px 0 0;\n  }\n  .start-card .eyebrow-plain { color: var(--orange); margin-bottom: 12px; }\n  .start-card h3 {\n    font-family: var(--font-serif);\n    font-weight: 700;\n    font-size: clamp(28px, 3vw, 40px);\n    line-height: 1.05;\n    color: #fff;\n    margin: 0 0 14px;\n    letter-spacing: -0.01em;\n  }\n  .start-card h3 .tp { color: var(--clear-blue); }\n  .start-card p {\n    color: rgba(247,246,242,0.85);\n    font-size: clamp(15px, 1.3vw, 17px);\n    line-height: 1.55;\n    margin: 0 0 20px;\n    max-width: 56ch;\n  }\n  .start-card .tip {\n    background: rgba(247,246,242,0.08);\n    border-left-color: var(--clear-blue);\n    margin: 0;\n  }\n  .start-card .tip .clbl { color: var(--clear-blue); }\n  .start-card .tip p { color: rgba(247,246,242,0.9); margin: 0; }\n\n  /* ——— Lists ——— */\n  ul.brand-list {\n    list-style: none;\n    padding: 0;\n    margin: 16px 0 24px;\n    display: grid;\n    gap: 10px;\n  }\n  ul.brand-list li {\n    position: relative;\n    padding-left: 28px;\n    font-size: 16px;\n    line-height: 1.55;\n    color: var(--dark-blue);\n  }\n  ul.brand-list li::before {\n    content: \"✓\";\n    position: absolute;\n    left: 0;\n    top: 0;\n    color: var(--orange);\n    font-weight: 700;\n  }\n\n  /* ——— Four-fix grid (step 3) ——— */\n  .fix-grid {\n    display: grid;\n    grid-template-columns: repeat(2, 1fr);\n    gap: 20px;\n    margin: 24px 0 8px;\n  }\n  .fix {\n    background: #fff;\n    border-radius: var(--r-md);\n    padding: 24px 26px;\n    border: 1px solid var(--border);\n  }\n  .fix__num {\n    font-family: var(--font-serif);\n    font-weight: 700;\n    font-style: italic;\n    font-size: 28px;\n    color: var(--clear-blue);\n    margin: 0 0 4px;\n    line-height: 1;\n  }\n  .fix h4 {\n    font-family: var(--font-sans);\n    font-weight: 700;\n    font-size: 17px;\n    color: var(--dark-blue);\n    margin: 0 0 8px;\n    line-height: 1.3;\n  }\n  .fix p {\n    font-size: 14.5px;\n    line-height: 1.55;\n    color: var(--dark-blue);\n    margin: 0;\n  }\n  @media (max-width: 720px) {\n    .fix-grid { grid-template-columns: 1fr; }\n  }\n\n  /* ——— Closing comparison (fout/fout/juist) ——— */\n  .judge {\n    display: grid;\n    gap: 12px;\n    margin: 20px 0 0;\n  }\n  .judge__row {\n    display: grid;\n    grid-template-columns: 90px 1fr;\n    gap: 20px;\n    align-items: stretch;\n    background: #fff;\n    border-radius: var(--r-md);\n    padding: 20px 24px;\n    border: 1px solid var(--border);\n  }\n  .judge__row.fout { border-left: 3px solid #C0392B; }\n  .judge__row.juist { border-left: 3px solid #1F8A5B; }\n  .judge__verdict {\n    font-family: var(--font-sans);\n    font-weight: 700;\n    font-size: 11px;\n    letter-spacing: 0.22em;\n    text-transform: uppercase;\n    display: flex;\n    align-items: center;\n  }\n  .judge__row.fout .judge__verdict { color: #C0392B; }\n  .judge__row.juist .judge__verdict { color: #1F8A5B; }\n  .judge__quote {\n    font-family: var(--font-serif);\n    font-style: italic;\n    font-size: clamp(17px, 1.6vw, 20px);\n    line-height: 1.35;\n    color: var(--dark-blue);\n    margin: 0 0 6px;\n  }\n  .judge__why {\n    font-size: 14.5px;\n    line-height: 1.5;\n    color: var(--fg-muted);\n    margin: 0;\n  }\n  @media (max-width: 640px) {\n    .judge__row { grid-template-columns: 1fr; gap: 8px; }\n  }\n\n  /* ——— Three-col \"Maak je AI-vaardigheid expliciet\" ——— */\n  .visible-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 1px;\n    background: var(--border);\n    border-radius: var(--r-md);\n    overflow: hidden;\n    border: 1px solid var(--border);\n    margin: 24px 0 0;\n  }\n  .visible-grid > div {\n    background: #fff;\n    padding: 24px 26px;\n  }\n  .visible-grid h4 {\n    font-family: var(--font-sans);\n    font-weight: 700;\n    font-size: 11px;\n    letter-spacing: 0.22em;\n    text-transform: uppercase;\n    color: var(--orange);\n    margin: 0 0 12px;\n  }\n  .visible-grid p {\n    font-size: 14.5px;\n    line-height: 1.55;\n    color: var(--dark-blue);\n    margin: 0;\n  }\n  .visible-grid em.q {\n    font-style: italic;\n    font-family: var(--font-serif);\n    font-size: 16px;\n    color: var(--dark-blue);\n    display: block;\n    margin: 2px 0;\n  }\n  @media (max-width: 800px) {\n    .visible-grid { grid-template-columns: 1fr; }\n  }\n\n  /* ——— Footer ——— */\n  .foot {\n    background: var(--dark-blue);\n    color: var(--fg-on-dark);\n    padding: clamp(56px, 7vw, 96px) 0 clamp(40px, 5vw, 56px);\n    margin-top: clamp(56px, 7vw, 80px);\n  }\n  .foot__inner {\n    max-width: 1120px;\n    margin: 0 auto;\n    padding: 0 24px;\n    display: grid;\n    grid-template-columns: 1fr auto;\n    gap: 48px;\n    align-items: end;\n  }\n  .foot__lbl {\n    font-family: var(--font-sans);\n    font-weight: 700;\n    font-size: 12px;\n    letter-spacing: 0.22em;\n    text-transform: uppercase;\n    color: var(--orange);\n    margin: 0 0 18px;\n  }\n  .foot h3 {\n    font-family: var(--font-serif);\n    font-weight: 700;\n    font-size: clamp(28px, 3.2vw, 44px);\n    line-height: 1.05;\n    color: #fff;\n    margin: 0 0 28px;\n    max-width: 18ch;\n    letter-spacing: -0.01em;\n  }\n  .foot h3 .tp { color: var(--clear-blue); }\n  .foot__links {\n    list-style: none;\n    padding: 0;\n    margin: 0;\n    display: grid;\n    gap: 10px;\n  }\n  .foot__links li {\n    display: grid;\n    grid-template-columns: 120px 1fr;\n    gap: 16px;\n    align-items: baseline;\n    font-size: 15px;\n  }\n  .foot__links .ch {\n    font-family: var(--font-sans);\n    font-weight: 700;\n    color: var(--clear-blue);\n    text-transform: uppercase;\n    font-size: 11px;\n    letter-spacing: 0.18em;\n  }\n  .foot__links a {\n    color: var(--fg-on-dark);\n    text-decoration: none;\n    border-bottom: 1px solid rgba(247,246,242,0.2);\n    padding-bottom: 2px;\n    transition: border-color var(--dur) var(--ease), color var(--dur) var(--ease);\n  }\n  .foot__links a:hover { color: var(--orange); border-color: var(--orange); }\n  .foot__logo { width: 140px; height: auto; }\n  .foot__copy {\n    margin-top: 48px;\n    padding-top: 24px;\n    border-top: 1px solid rgba(247,246,242,0.12);\n    max-width: 1120px;\n    padding-left: 24px;\n    padding-right: 24px;\n    margin-left: auto;\n    margin-right: auto;\n  }\n  .foot__copy p {\n    font-family: var(--font-sans);\n    font-weight: 700;\n    font-size: 11px;\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    color: rgba(247,246,242,0.55);\n    margin: 0;\n  }\n  @media (max-width: 720px) {\n    .foot__inner { grid-template-columns: 1fr; }\n    .foot__links li { grid-template-columns: 100px 1fr; }\n  }\n\n  /* ——— Sticky progress (top) ——— */\n  .progress {\n    position: sticky;\n    top: 0;\n    z-index: 30;\n    background: rgba(239,238,234,0.88);\n    backdrop-filter: blur(12px);\n    -webkit-backdrop-filter: blur(12px);\n    border-bottom: 1px solid var(--border);\n    transform: translateY(-100%);\n    transition: transform 320ms var(--ease);\n  }\n  .progress.is-on { transform: translateY(0); }\n  .progress__inner {\n    max-width: 1120px;\n    margin: 0 auto;\n    padding: 12px 24px;\n    display: flex;\n    align-items: center;\n    gap: 20px;\n  }\n  .progress__title {\n    font-family: var(--font-sans);\n    font-weight: 700;\n    font-size: 13px;\n    color: var(--dark-blue);\n    white-space: nowrap;\n  }\n  .progress__title .tp { color: var(--clear-blue); }\n  .progress__steps {\n    display: flex;\n    gap: 6px;\n    flex: 1;\n    align-items: center;\n  }\n  .progress__step {\n    flex: 1;\n    height: 3px;\n    background: var(--border);\n    border-radius: 999px;\n    cursor: pointer;\n    transition: background var(--dur) var(--ease);\n    position: relative;\n  }\n  .progress__step:hover { background: var(--border-strong); }\n  .progress__step.is-active { background: var(--orange); }\n  .progress__step.is-done { background: var(--dark-blue); }\n  .progress__count {\n    font-family: var(--font-sans);\n    font-weight: 700;\n    font-size: 11px;\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    color: var(--fg-muted);\n    white-space: nowrap;\n  }\n  @media (max-width: 640px) {\n    .progress__title { display: none; }\n  }\n\n  /* Anchor offset so sticky bar doesn't cover headings */\n  .anchor { scroll-margin-top: 80px; }\n\n  /* Small print */\n  .micro {\n    font-size: 13px;\n    color: var(--fg-muted);\n    margin: 8px 0 0;\n  }\n<\u002Fstyle>\n<\u002Fhead>\n<body>\n\n\n\n<!-- ——— Sticky top progress ——— -->\n<div class=\"progress\" id=\"progress\" aria-hidden=\"true\">\n  <div class=\"progress__inner\">\n    <div class=\"progress__title\">Hoe solliciteren in een AI-tijdperk<span class=\"tp\">.<\u002Fspan><\u002Fdiv>\n    <div class=\"progress__steps\" role=\"navigation\" aria-label=\"Stappen\">\n      <a class=\"progress__step\" data-step=\"1\" href=\"#stap-01\" aria-label=\"Stap 01 — Vinden\"><\u002Fa>\n      <a class=\"progress__step\" data-step=\"2\" href=\"#stap-02\" aria-label=\"Stap 02 — Begrijpen\"><\u002Fa>\n      <a class=\"progress__step\" data-step=\"3\" href=\"#stap-03\" aria-label=\"Stap 03 — Vertalen\"><\u002Fa>\n      <a class=\"progress__step\" data-step=\"4\" href=\"#stap-04\" aria-label=\"Stap 04 — Oefenen\"><\u002Fa>\n    <\u002Fdiv>\n    <div class=\"progress__count\" id=\"progress-count\">01 / 04<\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fdiv>\n\n<!-- ——— Hero ——— -->\n<header class=\"hero\">\n  <div class=\"hero__inner\">\n    <div>\n      <p class=\"hero__eyebrow\">EEN GIDS VAN EMMA DECLERCK<\u002Fp>\n      <h1 class=\"hero__title\">Hoe solliciteren in een AI-tijdperk<span class=\"tp\">.<\u002Fspan><\u002Fh1>\n      <p class=\"hero__sub\">Een praktische gids met de 4 stappen en prompts.<\u002Fp>\n    <\u002Fdiv>\n    <img class=\"hero__logo\" src=\"77cf30c6-9e7f-4d7e-bf26-f0b0c4d5afd2\" alt=\"emmadeclerck.ai\">\n  <\u002Fdiv>\n<\u002Fheader>\n\n<!-- ——— Intro ——— -->\n<section class=\"tight\">\n  <div class=\"wrap intro\">\n    <p class=\"pull\">Eén ding vooraf: AI doet niet de sollicitatie voor jou.<\u002Fp>\n    <p style=\"margin-top:24px;\">Jij blijft de regisseur. AI versnelt het zware werk en helpt je scherper voor de dag te komen. Wat je niet zelf kan onderbouwen in een gesprek, hoort niet op je CV.<\u002Fp>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- ——— Voor je start ——— -->\n<section class=\"tight\">\n  <div class=\"wrap\">\n    <p class=\"eyebrow-plain\">Voor je start<\u002Fp>\n    <div class=\"start-card\">\n      <h3>Maak een project aan<span class=\"tp\">.<\u002Fspan><\u002Fh3>\n      <p>Zet al je chats en bestanden op één plek. In ChatGPT (of Claude, Gemini) kan je een <strong>Project<\u002Fstrong> aanmaken. Daar upload je later je CV, vacatures en het \"over mezelf\"-document, en hou je per bedrijf een aparte chat. Zo vermist AI minder context en hoef je nooit dezelfde info opnieuw te geven.<\u002Fp>\n      <div class=\"callout tip\">\n        <p class=\"clbl\">Tip<\u002Fp>\n        <p>Je moet ingelogd zijn om Projects te gebruiken.<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<hr class=\"rule\">\n\n<!-- ——— STAP 01 — Vinden ——— -->\n<section id=\"stap-01\" class=\"anchor\" data-step=\"1\">\n  <div class=\"wrap\">\n    <div class=\"step-head\">\n      <p class=\"lbl\">Stap 01 van 04<\u002Fp>\n      <h2>Vinden<span class=\"tp\">.<\u002Fspan><\u002Fh2>\n      <p class=\"lede\">Solliciteren start niet met een CV, maar bij jezelf. Zonder een helder beeld van wat je wil en kan, is je AI-output niet afgestemd op jouw noden en talenten.<\u002Fp>\n    <\u002Fdiv>\n\n    <h3 class=\"sub-h first\"><span class=\"num\">1.<\u002Fspan>Maak een \"over mezelf\"-document<\u002Fh3>\n    <p>Laat AI je interviewen. Eén vraag per keer. Aan het einde heb je een document dat je in elke volgende prompt als bijlage meegeeft.<\u002Fp>\n\n    <div class=\"prompt\">\n      <div class=\"prompt__head\">\n        <span class=\"prompt__lbl\">Prompt<\u002Fspan>\n        <button class=\"prompt__copy\" type=\"button\" aria-label=\"Kopieer prompt\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"9\" y=\"9\" width=\"13\" height=\"13\" rx=\"2\"><\u002Frect><path d=\"M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1\"><\u002Fpath><\u002Fsvg>\n          <span class=\"copy-label\">Kopieer<\u002Fspan>\n        <\u002Fbutton>\n      <\u002Fdiv>\n      <div class=\"prompt__body\">\n        <p>\"Ik ga solliciteren en wil eerst uitzoeken welke jobs bij mij passen. Stel mij één vraag per keer om een over mezelf-document te maken dat goed samenvat wie ik ben, wat ik belangrijk vind, waar ik goed en minder goed in ben, etc., zodat ik dit kan gebruiken als basis in mijn jobzoektocht.\"<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"callout result\">\n      <p class=\"clbl\">Resultaat<\u002Fp>\n      <p>Een document <strong>Over mezelf.doc<\u002Fstrong>. Sla het op in je Project en verwijs ernaar in je volgende prompts. Dit is je rode draad.<\u002Fp>\n    <\u002Fdiv>\n\n    <h3 class=\"sub-h\"><span class=\"num\">2.<\u002Fspan>Laat AI 100en vacatures voor je scannen<\u002Fh3>\n    <p>Wat jij in een paar uur browsen doet, doet AI in een paar minuten. Vraag om een tabel zodat je later zelf kan filteren en sorteren.<\u002Fp>\n\n    <div class=\"prompt\">\n      <div class=\"prompt__head\">\n        <span class=\"prompt__lbl\">Prompt<\u002Fspan>\n        <button class=\"prompt__copy\" type=\"button\" aria-label=\"Kopieer prompt\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"9\" y=\"9\" width=\"13\" height=\"13\" rx=\"2\"><\u002Frect><path d=\"M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1\"><\u002Fpath><\u002Fsvg>\n          <span class=\"copy-label\">Kopieer<\u002Fspan>\n        <\u002Fbutton>\n      <\u002Fdiv>\n      <div class=\"prompt__body\">\n        <p>\"Vind 50 vacatures in België die passen bij mijn profiel. Zet ze in een tabel met functietitel, bedrijf, locatie, bron en URL. Rangschik ze volgens match.\"<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"callout watch\">\n      <p class=\"clbl\">Watch-out<\u002Fp>\n      <p>AI kan vacatures verzinnen of links produceren die niet werken. Klik elke URL aan voor je solliciteert. Geen werkende link = schrappen.<\u002Fp>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<hr class=\"rule\">\n\n<!-- ——— STAP 02 — Begrijpen ——— -->\n<section id=\"stap-02\" class=\"anchor\" data-step=\"2\">\n  <div class=\"wrap\">\n    <div class=\"step-head\">\n      <p class=\"lbl\">Stap 02 van 04<\u002Fp>\n      <h2>Begrijpen<span class=\"tp\">.<\u002Fspan><\u002Fh2>\n      <p class=\"lede\">Eens je weet waar je wil solliciteren, doorgrond je het bedrijf voor je binnenstapt. Niet alleen om recruiters te imponeren met hoe goed je hun bedrijf kent, maar ook om voor jezelf in te schatten of het bedrijf bij jou past en welke vragen je tijdens het gesprek wil stellen.<\u002Fp>\n    <\u002Fdiv>\n\n    <h3 class=\"sub-h first\">Werk dit uit in NotebookLM<\u002Fh3>\n    <p>NotebookLM (gratis, van Google) is hier sterker dan ChatGPT: het werkt alleen op de bronnen die jij oplaadt en geeft bij elk antwoord de bronverwijzing erbij. Veel minder hallucinaties.<\u002Fp>\n\n    <h4 style=\"font-family:var(--font-sans);font-weight:700;font-size:17px;color:var(--dark-blue);margin:24px 0 4px;\">Welke bronnen vraag je op?<\u002Fh4>\n    <ul class=\"brand-list\">\n      <li>Officiële site, dienstenpagina's, cases en blog<\u002Fli>\n      <li>LinkedIn bedrijfspagina en recente posts van medewerkers<\u002Fli>\n      <li>Glassdoor of Indeed reviews<\u002Fli>\n      <li>Persberichten en artikels in vakbladen van de laatste 12 maanden<\u002Fli>\n      <li>Interviews of podcasts met oprichters of leiderschap<\u002Fli>\n      <li>Vacatureteksten die hun cultuur en werkwijze blootleggen<\u002Fli>\n    <\u002Ful>\n\n    <div class=\"prompt\">\n      <div class=\"prompt__head\">\n        <span class=\"prompt__lbl\">Prompts (suggesties)<\u002Fspan>\n        <button class=\"prompt__copy\" type=\"button\" aria-label=\"Kopieer prompt\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"9\" y=\"9\" width=\"13\" height=\"13\" rx=\"2\"><\u002Frect><path d=\"M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1\"><\u002Fpath><\u002Fsvg>\n          <span class=\"copy-label\">Kopieer<\u002Fspan>\n        <\u002Fbutton>\n      <\u002Fdiv>\n      <div class=\"prompt__body\">\n        <p>\"Geef mij een overzicht van wat dit bedrijf doet, voor wie, en hoe het geld verdient. Wat zijn hun grootste uitdagingen op dit moment? Welke thema's komen telkens terug in hun communicatie? Welke vragen zou ik stellen om te tonen dat ik me ingelezen heb?\"<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<hr class=\"rule\">\n\n<!-- ——— STAP 03 — Vertalen ——— -->\n<section id=\"stap-03\" class=\"anchor\" data-step=\"3\">\n  <div class=\"wrap\">\n    <div class=\"step-head\">\n      <p class=\"lbl\">Stap 03 van 04<\u002Fp>\n      <h2>Vertalen<span class=\"tp\">.<\u002Fspan><\u002Fh2>\n      <p class=\"lede\">Je CV moet werken voor mens én machine. Bij veel grote werkgevers loopt het eerst door een ATS (Applicant Tracking System) dat woorden in je CV vergelijkt met de vacaturetekst. Hoe dichter de match, hoe groter de kans dat een recruiter je CV bovenaan de stapel legt.<\u002Fp>\n    <\u002Fdiv>\n\n    <h3 class=\"sub-h first\">Vier fixes voor een CV die werkt voor mens én machine<\u002Fh3>\n\n    <div class=\"fix-grid\">\n      <div class=\"fix\">\n        <p class=\"fix__num\">01<\u002Fp>\n        <h4>Maximale leesbaarheid<\u002Fh4>\n        <p>Eén kolom, standaardfont (bv. Arial), geen tekstvakken, geen tabellen voor layout, geen essentiële info in header of footer. Een ATS leest lineair van boven naar onder.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"fix\">\n        <p class=\"fix__num\">02<\u002Fp>\n        <h4>Bekende sectiekoppen en functienamen<\u002Fh4>\n        <p>Gebruik standaardlabels: Profiel, Opleiding, Werkervaring, Vaardigheden, Talen. Een creatieve titel als \"Mijn reis\" mist de ATS. Afwijkende functietitel? Zet de gangbare ernaast: \"Growth Lead (Marketing Manager)\".<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"fix\">\n        <p class=\"fix__num\">03<\u002Fp>\n        <h4>Keywords uit de vacature<\u002Fh4>\n        <p>Neem letterlijke termen over: tools, methodes, certificaten, functietitels. Schrijf acroniemen voluit én afgekort: \"Search Engine Optimization (SEO)\". Geen lijstjes met losse buzzwords, integreer ze in je ervaring.<\u002Fp>\n      <\u002Fdiv>\n      <div class=\"fix\">\n        <p class=\"fix__num\">04<\u002Fp>\n        <h4>Consistente datums en structuur<\u002Fh4>\n        <p>Eén formaat door je hele CV: \"09/2022 – 06/2025\" of \"September 2022 tot juni 2025\". Per functie altijd dezelfde volgorde: titel, bedrijf, locatie, periode, daarna pas de bullets.<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <h3 class=\"sub-h\"><span class=\"num\">1.<\u002Fspan>Stem je CV af op de vacature<\u002Fh3>\n    <p>Voor elke sollicitatie maak je een nieuwe versie van je CV. Niet alles herschrijven, wel keywords en accenten verschuiven.<\u002Fp>\n\n    <div class=\"prompt\">\n      <div class=\"prompt__head\">\n        <span class=\"prompt__lbl\">Prompt<\u002Fspan>\n        <button class=\"prompt__copy\" type=\"button\" aria-label=\"Kopieer prompt\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"9\" y=\"9\" width=\"13\" height=\"13\" rx=\"2\"><\u002Frect><path d=\"M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1\"><\u002Fpath><\u002Fsvg>\n          <span class=\"copy-label\">Kopieer<\u002Fspan>\n        <\u002Fbutton>\n      <\u002Fdiv>\n      <div class=\"prompt__body\">\n        <p>\"Stem mijn CV maximaal af op deze vacature, rekening houdend met mijn over mezelf-document en aangepast voor ATS-systemen.\"<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"callout watch\">\n      <p class=\"clbl\">Watch-out<\u002Fp>\n      <p>Vermijd keyword-stuffing. Gebruik alleen termen die je in een gesprek echt hard kan maken, en zet ze op de plek waar ze logisch passen (skills, ervaring, projecten). Een woord dat je niet kan uitleggen valt door de mand bij de eerste vervolgvraag.<\u002Fp>\n    <\u002Fdiv>\n\n    <h3 class=\"sub-h\"><span class=\"num\">2.<\u002Fspan>Laat AI je CV scoren tegen de vacature<\u002Fh3>\n    <p>Bouw een kwaliteitscontrole in om jouw — samen met AI gegenereerde — CV te checken op vacature-cv fit. Dat doe je via de rubric-methode.<\u002Fp>\n\n    <div class=\"prompt\">\n      <div class=\"prompt__head\">\n        <span class=\"prompt__lbl\">Prompt — 3 stappen na elkaar<\u002Fspan>\n        <button class=\"prompt__copy\" type=\"button\" aria-label=\"Kopieer prompt\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"9\" y=\"9\" width=\"13\" height=\"13\" rx=\"2\"><\u002Frect><path d=\"M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1\"><\u002Fpath><\u002Fsvg>\n          <span class=\"copy-label\">Kopieer<\u002Fspan>\n        <\u002Fbutton>\n      <\u002Fdiv>\n      <div class=\"prompt__body\">\n        <p>\"1. Maak een rubric voor een goede vacature-CV fit, geoptimaliseerd voor ATS-filters.<\u002Fp>\n        <p>2. Scoor mijn CV op basis van deze rubric en deze vacature.<\u002Fp>\n        <p>3. Herwerk mijn CV zodat ik 9/10 scoor.\"<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"callout tip\">\n      <p class=\"clbl\">Tip<\u002Fp>\n      <p>Je kan je CV ook gratis laten checken op <a href=\"https://jobscan.co\" style=\"color:var(--dark-blue);text-decoration:underline;\">jobscan.co<\u002Fa>. Daar zie je je match-score, ontbrekende keywords en formattering die ATS lastig leest.<\u002Fp>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<hr class=\"rule\">\n\n<!-- ——— STAP 04 — Oefenen ——— -->\n<section id=\"stap-04\" class=\"anchor\" data-step=\"4\">\n  <div class=\"wrap\">\n    <div class=\"step-head\">\n      <p class=\"lbl\">Stap 04 van 04<\u002Fp>\n      <h2>Oefenen<span class=\"tp\">.<\u002Fspan><\u002Fh2>\n      <p class=\"lede\">Het verschil tussen gemiddeld en goed in een gesprek zit zelden in wat je weet. Het zit in hoe vlot je je verhaal kan brengen onder lichte druk. Dat oefen je met AI, op elk moment van de dag.<\u002Fp>\n    <\u002Fdiv>\n\n    <h3 class=\"sub-h first\">Rollenspel met ChatGPT in voice mode<\u002Fh3>\n    <p>Laat AI de HR-persoon spelen. Eén vraag per keer, gevolgd door feedback. Zo weet je wat je beter wél en niet zegt.<\u002Fp>\n\n    <div class=\"prompt\">\n      <div class=\"prompt__head\">\n        <span class=\"prompt__lbl\">Voice mode prompt<\u002Fspan>\n        <button class=\"prompt__copy\" type=\"button\" aria-label=\"Kopieer prompt\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"9\" y=\"9\" width=\"13\" height=\"13\" rx=\"2\"><\u002Frect><path d=\"M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1\"><\u002Fpath><\u002Fsvg>\n          <span class=\"copy-label\">Kopieer<\u002Fspan>\n        <\u002Fbutton>\n      <\u002Fdiv>\n      <div class=\"prompt__body\">\n        <p>\"Speel een strenge recruiter bij [bedrijfsnaam]. Oefen mijn sollicitatiegesprek voor bijgevoegde vacature. Stel mij één vraag per keer. Geef mij na elk antwoord de red flags en formuleer het beste antwoord op basis van mijn achtergrond en CV.\"<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"callout tip\">\n      <p class=\"clbl\">Tip<\u002Fp>\n      <p>Gebruik voice mode (mic-icoon onder de chat). Je spreekt 4× sneller dan je typt en je hoort tegelijk hoe je je verhaal hardop verwoordt.<\u002Fp>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<hr class=\"rule\">\n\n<!-- ——— TOT SLOT ——— -->\n<section id=\"tot-slot\" class=\"anchor\">\n  <div class=\"wrap\">\n    <div class=\"step-head\">\n      <p class=\"lbl\">Tot slot<\u002Fp>\n      <h2>Hoe je het in het gesprek brengt<span class=\"tp\">.<\u002Fspan><\u002Fh2>\n      <p class=\"lede\">Het juiste antwoord op de vraag: <em style=\"font-family:var(--font-serif);font-style:italic;\">\"Heb je AI gebruikt voor deze sollicitatie?\"<\u002Fem><\u002Fp>\n    <\u002Fdiv>\n\n    <div class=\"judge\">\n      <div class=\"judge__row fout\">\n        <div class=\"judge__verdict\">Fout<\u002Fdiv>\n        <div>\n          <p class=\"judge__quote\">\"Nee, niet nodig.\"<\u002Fp>\n          <p class=\"judge__why\">Je toont dat je niet meegaat in hoe werk vandaag gebeurt.<\u002Fp>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"judge__row fout\">\n        <div class=\"judge__verdict\">Fout<\u002Fdiv>\n        <div>\n          <p class=\"judge__quote\">\"Ja, ChatGPT heeft alles voor mij geschreven.\"<\u002Fp>\n          <p class=\"judge__why\">Je toont dat je geen eigen oordeel hebt.<\u002Fp>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"judge__row juist\">\n        <div class=\"judge__verdict\">Juist<\u002Fdiv>\n        <div>\n          <p class=\"judge__quote\">\"Ja. Deze stappen liet ik over aan AI. Dit deed ik zelf. En dit is hoe ik de output kritisch beoordeeld heb.\"<\u002Fp>\n          <p class=\"judge__why\">Je toont oordeel, eigenaarschap en methode.<\u002Fp>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <h3 class=\"sub-h\">Maak je AI-vaardigheid expliciet zichtbaar<span class=\"tp\">.<\u002Fspan><\u002Fh3>\n\n    <div class=\"visible-grid\">\n      <div>\n        <h4>Op je CV<\u002Fh4>\n        <p>Welke AI-tools je gebruikt hebt. Concrete use cases die je getest hebt (stage, projecten, vrije tijd).<\u002Fp>\n      <\u002Fdiv>\n      <div>\n        <h4>In het gesprek<\u002Fh4>\n        <p>Hoe je AI ingezet hebt in je voorbereiding. Hoe je AI zou gebruiken in hun bedrijfscontext.<\u002Fp>\n      <\u002Fdiv>\n      <div>\n        <h4>Vraag aan de recruiter<\u002Fh4>\n        <em class=\"q\">\"Welke rol speelt AI in jullie bedrijf?\"<\u002Fem>\n        <em class=\"q\">\"Welke AI-tools gebruiken jullie?\"<\u002Fem>\n        <em class=\"q\">\"Wat is jullie AI-policy?\"<\u002Fem>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- ——— Footer ——— -->\n<footer class=\"foot\">\n  <div class=\"foot__inner\">\n    <div>\n      <p class=\"foot__lbl\">Volg voor meer AI tips &amp; trainingen<\u002Fp>\n      <h3>Blijf scherp in een AI-first wereld<span class=\"tp\">.<\u002Fspan><\u002Fh3>\n      <ul class=\"foot__links\">\n        <li><span class=\"ch\">LinkedIn<\u002Fspan><a href=\"https://www.linkedin.com/in/emmadeclerck\" target=\"_blank\" rel=\"noopener\">linkedin.com/in/emmadeclerck<\u002Fa><\u002Fli>\n        <li><span class=\"ch\">Instagram<\u002Fspan><a href=\"https://www.instagram.com/emmadeclerck.ai/\" target=\"_blank\" rel=\"noopener\">instagram.com/emmadeclerck.ai<\u002Fa><\u002Fli>\n        <li><span class=\"ch\">Nieuwsbrief<\u002Fspan><a href=\"https://www.emmadeclerck.ai/nieuwsbrief\" target=\"_blank\" rel=\"noopener\">emmadeclerck.ai/nieuwsbrief<\u002Fa><\u002Fli>\n        <li><span class=\"ch\">Website<\u002Fspan><a href=\"https://www.emmadeclerck.ai\" target=\"_blank\" rel=\"noopener\">emmadeclerck.ai<\u002Fa><\u002Fli>\n      <\u002Ful>\n    <\u002Fdiv>\n    <img class=\"foot__logo\" src=\"77cf30c6-9e7f-4d7e-bf26-f0b0c4d5afd2\" alt=\"emmadeclerck.ai\">\n  <\u002Fdiv>\n  <div class=\"foot__copy\">\n    <p>© 2026 EMMADECLERCK.AI | ALL RIGHTS RESERVED.<\u002Fp>\n  <\u002Fdiv>\n<\u002Ffooter>\n\n<script>\n  // ——— Copy-to-clipboard for prompts ———\n  document.querySelectorAll('.prompt').forEach(function(p){\n    var btn = p.querySelector('.prompt__copy');\n    var body = p.querySelector('.prompt__body');\n    if (!btn || !body) return;\n    btn.addEventListener('click', function(){\n      var text = body.innerText.trim();\n      // strip surrounding quotes if entire block is one quoted string\n      navigator.clipboard.writeText(text).then(function(){\n        btn.classList.add('is-copied');\n        var lbl = btn.querySelector('.copy-label');\n        var orig = lbl ? lbl.textContent : 'Kopieer';\n        if (lbl) lbl.textContent = 'Gekopieerd';\n        setTimeout(function(){\n          btn.classList.remove('is-copied');\n          if (lbl) lbl.textContent = orig;\n        }, 1600);\n      }).catch(function(){\n        // fallback\n        var ta = document.createElement('textarea');\n        ta.value = text; document.body.appendChild(ta); ta.select();\n        try { document.execCommand('copy'); } catch(e){}\n        document.body.removeChild(ta);\n      });\n    });\n  });\n\n  // ——— Sticky progress bar ———\n  var progress = document.getElementById('progress');\n  var stepEls = Array.from(document.querySelectorAll('section[data-step]'));\n  var stepBars = Array.from(document.querySelectorAll('.progress__step'));\n  var countEl = document.getElementById('progress-count');\n  var hero = document.querySelector('.hero');\n\n  function onScroll(){\n    var heroBottom = hero.getBoundingClientRect().bottom;\n    if (heroBottom < 0) progress.classList.add('is-on');\n    else progress.classList.remove('is-on');\n\n    // find current step\n    var current = 0;\n    stepEls.forEach(function(sec, i){\n      var top = sec.getBoundingClientRect().top;\n      if (top < window.innerHeight * 0.4) current = i + 1;\n    });\n\n    stepBars.forEach(function(bar, i){\n      bar.classList.toggle('is-active', (i+1) === current);\n      bar.classList.toggle('is-done', (i+1) < current);\n    });\n    if (countEl) {\n      var n = current > 0 ? String(current).padStart(2,'0') : '01';\n      countEl.textContent = n + ' / 04';\n    }\n  }\n  window.addEventListener('scroll', onScroll, { passive: true });\n  onScroll();\n<\u002Fscript>\n\n\n\n<\u002Fbody><\u002Fhtml>"
  </script>
