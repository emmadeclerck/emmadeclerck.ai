ir Display', Georgia, serif;\n  --font-sans:  'Poppins', -apple-system, 'Helvetica Neue', Arial, sans-serif;\n\n  /* Scale (marketing) */\n  --fs-display: clamp(48px, 7vw, 96px);\n  --fs-h1:      clamp(40px, 5vw, 64px);\n  --fs-h2:      clamp(32px, 3.6vw, 44px);\n  --fs-h3:      clamp(22px, 2.2vw, 28px);\n  --fs-h4:      18px;\n  --fs-body:    17px;\n  --fs-small:   14px;\n  --fs-eyebrow: 12px;\n\n  /* ——— Radii ——— */\n  --r-sm:   8px;\n  --r-md:   16px;\n  --r-lg:   24px;\n  --r-pill: 999px;\n  --r-btn:  10px;\n\n  /* ——— Shadow ——— */\n  --shadow-card:  0 12px 32px -12px rgba(3,40,95,0.18);\n  --shadow-float: 0 24px 48px -16px rgba(3,40,95,0.28);\n\n  /* ——— Spacing ——— */\n  --s-1:  4px;\n  --s-2:  8px;\n  --s-3:  12px;\n  --s-4:  16px;\n  --s-5:  24px;\n  --s-6:  32px;\n  --s-7:  48px;\n  --s-8:  64px;\n  --s-9:  96px;\n  --s-10: 128px;\n\n  /* ——— Motion ——— */\n  --dur: 220ms;\n  --ease: cubic-bezier(.2,.7,.2,1);\n}\n\nhtml { -webkit-font-smoothing: antialiased; }\nbody {\n  background: var(--bg);\n  color: var(--fg1);\n  font-family: var(--font-sans);\n  font-size: var(--fs-body);\n  line-height: 1.55;\n  margin: 0;\n}\n\n/* ——— Semantic type ——— */\n.display, .h-display {\n  font-family: var(--font-serif);\n  font-weight: 700;\n  font-size: var(--fs-display);\n  line-height: 0.98;\n  letter-spacing: -0.01em;\n  color: var(--fg1);\n  margin: 0;\n}\nh1, .h1 {\n  font-family: var(--font-serif);\n  font-weight: 700;\n  font-size: var(--fs-h1);\n  line-height: 1.02;\n  letter-spacing: -0.01em;\n  color: var(--fg1);\n  margin: 0 0 var(--s-4);\n}\nh2, .h2 {\n  font-family: var(--font-sans);\n  font-weight: 900;\n  font-size: var(--fs-h2);\n  line-height: 1.05;\n  letter-spacing: -0.01em;\n  color: var(--fg1);\n  margin: 0 0 var(--s-4);\n}\nh3, .h3 {\n  font-family: var(--font-sans);\n  font-weight: 700;\n  font-size: var(--fs-h3);\n  line-height: 1.2;\n  color: var(--fg1);\n  margin: 0 0 var(--s-3);\n}\nh4, .h4 {\n  font-family: var(--font-sans);\n  font-weight: 700;\n  font-size: var(--fs-h4);\n  line-height: 1.3;\n  color: var(--fg1);\n  margin: 0 0 var(--s-2);\n  text-transform: none;\n}\n.eyebrow {\n  font-family: var(--font-sans);\n  font-weight: 700;\n  font-size: var(--fs-eyebrow);\n  letter-spacing: 0.14em;\n  text-transform: uppercase;\n  color: var(--fg-muted);\n  margin: 0 0 var(--s-3);\n}\np, .p {\n  font-family: var(--font-sans);\n  font-size: var(--fs-body);\n  line-height: 1.55;\n  color: var(--fg1);\n  margin: 0 0 var(--s-4);\n  text-wrap: pretty;\n}\n.quote {\n  font-family: var(--font-serif);\n  font-style: italic;\n  font-weight: 400;\n  font-size: clamp(22px, 2.6vw, 32px);\n  line-height: 1.3;\n  color: var(--fg1);\n}\n.small { font-size: var(--fs-small); color: var(--fg-muted); }\n\n/* ——— Title final-punctuation rule ———\n   Emma's headings end in a period; that terminal glyph is ALWAYS clear-blue.\n   Two ways to apply:\n     1. Put the mark in a <span class=\"tp\">.<\u002Fspan> (recommended — precise).\n     2. Apply class \"has-tp\" on the heading and the CSS will color the last\n        character visually via the trailing pseudo-element (use ONLY when the\n        heading ends in a single period and the source text has the period\n        stripped from the element).\n*/\n.tp { color: var(--clear-blue); }\nh1 .tp, h2 .tp, h3 .tp, h4 .tp,\n.h1 .tp, .h2 .tp, .h3 .tp, .h4 .tp,\n.display .tp, .hero__title .tp { color: var(--clear-blue); }\n\na { color: var(--fg1); text-decoration: underline; text-underline-offset: 3px; text-decoration-thickness: 1px; }\na:hover { color: var(--accent); }\n\n/* ——— Primitives ——— */\n.btn {\n  display: inline-flex; align-items: center; gap: 8px;\n  font-family: var(--font-sans); font-weight: 700; font-size: 15px;\n  padding: 14px 24px; border-radius: var(--r-btn);\n  border: 0; cursor: pointer; text-decoration: none;\n  transition: background var(--dur) var(--ease), transform var(--dur) var(--ease);\n}\n.btn-primary { background: var(--accent); color: #fff; }\n.btn-primary:hover { background: var(--accent-hover); color: #fff; }\n.btn-primary:active { transform: scale(0.98); }\n.btn-ghost { background: transparent; color: var(--fg1); border: 1px solid var(--border-strong); }\n.btn-ghost:hover { background: rgba(3,40,95,0.05); color: var(--fg1); }\n.btn-dark { background: var(--dark-blue); color: #fff; }\n.btn-dark:hover { background: #021d47; color: #fff; }\n\n.card {\n  background: #fff;\n  border-radius: var(--r-md);\n  padding: var(--s-6);\n  box-shadow: var(--shadow-card);\n}\n\n.pill {\n  display: inline-flex; align-items: center; gap: 6px;\n  padding: 6px 12px; border-radius: var(--r-pill);\n  background: rgba(3,40,95,0.06); color: var(--fg1);\n  font-size: 13px; font-weight: 500;\n}\n<\u002Fstyle>\n<style>\n  /* ——— Page scaffold ——— */\n  html, body { background: var(--grey); }\n  body { color: var(--fg1); }\n  ::selection { background: var(--orange); color: #fff; }\n\n  .wrap { max-width: 760px; margin: 0 auto; padding: 0 24px; }\n  .wrap-wide { max-width: 1120px; margin: 0 auto; padding: 0 24px; }\n\n  /* ——— Hero ——— */\n  .hero {\n    background: var(--orange);\n    color: #fff;\n    padding: clamp(56px, 9vw, 112px) 0 clamp(64px, 10vw, 128px);\n    position: relative;\n    overflow: hidden;\n  }\n  .hero__inner {\n    max-width: 1120px;\n    margin: 0 auto;\n    padding: 0 24px;\n    display: grid;\n    grid-template-columns: 1fr auto;\n    gap: 32px;\n    align-items: start;\n  }\n  .hero__eyebrow {\n    font-family: var(--font-sans);\n    font-weight: 700;\n    font-size: 12px;\n    letter-spacing: 0.22em;\n    text-transform: uppercase;\n    color: rgba(255,255,255,0.75);\n    margin: 0 0 24px;\n  }\n  .hero__title {\n    font-family: var(--font-serif);\n    font-weight: 700;\n    font-size: clamp(44px, 6.4vw, 84px);\n    line-height: 1.02;\n    letter-spacing: -0.012em;\n    color: #fff;\n    margin: 0 0 24px;\n    max-width: 14ch;\n    text-wrap: balance;\n  }\n  .hero__title .tp { color: var(--clear-blue); }\n  .hero